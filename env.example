# =============================================================================
# Solaris booking AI — copy this file to .env.local and fill in values.
# Next.js loads .env.local automatically (never commit .env.local).
# =============================================================================

# -----------------------------------------------------------------------------
# 1) OpenAI (required)
# -----------------------------------------------------------------------------
# Create a key: https://platform.openai.com/api-keys
# Billing must be enabled on the OpenAI account for API calls to work.
OPENAI_API_KEY=sk-...

# Optional — default is gpt-4o-mini (cheap + good for tool use)
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# 2) Google Calendar (service account)
# -----------------------------------------------------------------------------
# A) Google Cloud Console: https://console.cloud.google.com/
#    - Create or pick a project.
#    - APIs & Services → Enable APIs → search "Google Calendar API" → Enable.
#
# B) IAM → Service Accounts → Create service account (any name).
#    - Keys → Add key → JSON → download the .json file. Keep it secret.
#
# C) Open the JSON file. Note client_email (looks like xxx@xxx.iam.gserviceaccount.com).
#
# D) Google Calendar (calendar.google.com) → Settings (gear) → Settings for my calendars
#    → your calendar → Share with specific people → Add the service account email
#    → Permission: "Make changes to events" → Send.
#
# E) Base64-encode the entire JSON file (one line for .env):
#    PowerShell:
#      [Convert]::ToBase64String([IO.File]::ReadAllBytes("C:\path\to\key.json"))
#    macOS/Linux:
#      base64 -i key.json | tr -d '\n'
#
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# The calendar that has been shared with the service account — usually your Gmail:
#   you@gmail.com
# Or a calendar ID from: Calendar settings → Integrate calendar → Calendar ID
GOOGLE_CALENDAR_ID=you@gmail.com

# -----------------------------------------------------------------------------
# 3) Business rules (IANA timezone)
# -----------------------------------------------------------------------------
# Used for 9:00–19:00 slots and the “two days ahead” rule.
# Pick yours: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
BOOKING_TIMEZONE=Australia/Sydney

# -----------------------------------------------------------------------------
# 4) What the site sends (no env vars)
# -----------------------------------------------------------------------------
# Full name / business name + email from the form are sent with each chat request.
# The server uses them for the Google event title, attendee invite, and Meet guest.
